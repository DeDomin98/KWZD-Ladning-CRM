rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Użytkownicy
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Czaty
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // 3. Collection Group Query dla wiadomości
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null && resource.data.receiverId == request.auth.uid;
    }
    
    // 4. Zaproszenia (Invitations)
    match /invitations/{id} { 
      allow read: if true; 
      allow write: if request.auth != null; 
    }
    
    match /emailQueue/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
    
    // ===== LEADS - pozwól na zapis z sekretem LUB zalogowanemu =====
    match /leads/{leadId} { 
      allow read: if request.auth != null;
      allow create: if request.auth != null || request.resource.data.apiSecret == "wzd-leads-2024-h8sk2nf";
      allow update, delete: if request.auth != null;
    }
    
    // Kolejka leadów (możesz usunąć jeśli nie używasz)
    match /leadsQueue/{docId} {
      allow create: if request.resource.data.apiSecret == "wzd-leads-2024-h8sk2nf";
      allow read, update, delete: if request.auth != null;
    }
  
    // Koszty (zakładka Finanse – tylko zalogowani)
    match /costs/{costId} {
      allow read, write: if request.auth != null;
    }
  
    // 5. Pozostałe kolekcje CRM
    match /reminders/{id} { allow read, write: if request.auth != null; }
    match /settings/{id} { allow read, write: if request.auth != null; }

    // Umowy - klient może odczytać i podpisać bez logowania (link z emaila)
    match /contracts/{contractId} { 
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null 
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'signedAt', 'signedViaEmail', 'signedFromDevice', 'signedIP']);
    }
    
    // Historia połączeń telefonicznych
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    // Presence agentów telefonicznych
    match /agents/{agentId} {
      allow read, write: if request.auth != null;
    }

    // Wiadomości SMS – odczyt dla zalogowanych, zapis przez Functions (admin SDK)
    match /sms/{messageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  
  }
}
